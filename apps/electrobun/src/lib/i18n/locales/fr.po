#: src/lib/i18n/hud.messages.ts:4
msgid "Points d'énergie : perdus en cas de mort. Régénérés en se déconnectant dans une zone de sauvegarde."
msgstr "Points d'énergie : perdus en cas de mort. Régénérés en se déconnectant dans une zone de sauvegarde."

#: src/lib/i18n/hud.messages.ts:5
msgid "Points d'expérience : en gagnant suffisamment de points d'expérience, vous gagnez un niveau."
msgstr "Points d'expérience : en gagnant suffisamment de points d'expérience, vous gagnez un niveau."

#: src/lib/i18n/hud.messages.ts:17
msgid "Points de capital : utilisez-les pour augmenter vos caractéristiques."
